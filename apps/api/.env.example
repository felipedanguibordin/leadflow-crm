# LeadFlow API — copy to `.env` in this folder for local development

NODE_ENV=development
PORT=3000

JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

DB_HOST=localhost
DB_PORT=5432
DB_USER=leadflow
DB_PASSWORD=leadflow
DB_NAME=leadflow

REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible) — fake local object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=leadflow-uploads
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_FORCE_PATH_STYLE=true

CORS_ORIGIN=http://localhost:4200
